# ==============================================================================
# CONFIGURAÇÕES DO NAVIÊ VIBE (EXEMPLO DE VARIÁVEIS DE AMBIENTE)
# ==============================================================================
# Copie este arquivo para um arquivo chamado '.env' na raiz do projeto e configure
# as suas credenciais reais de desenvolvimento, sandbox ou produção.
# ==============================================================================

# Chaves Oficiais de Integração do Mercado Pago (Checkout Transparente)
MERCADOPAGO_PUBLIC_KEY=sua_chave_publica_aqui
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui

# Configurações do Banco de Dados (Futura migração para PostgreSQL/MySQL)
# DATABASE_URL=postgres://usuario:senha@host:porta/banco

# Configurações de API do Google Maps
# GOOGLE_API_KEY=sua_google_maps_key_aqui
